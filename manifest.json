{
  "manifest_version": 3,
  "name": "CP Translator",
  "version": "1.1",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://www.acmicpc.net/*",
    "*://codeforces.com/*",
    "*://atcoder.jp/*"
  ]
}